{
  "manifest_version": 3,
  "name": "LEARN Gemini Navigator",
  "version": "1.0",
  "description": "Navigate Waterloo LEARN using Gemini AI and natural-language prompts",
  "permissions": ["activeTab", "scripting", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://learn.uwaterloo.ca/d2l/*"],
      "js": ["content.js"]
    }
  ]
}
